{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waveframe.ai/schemas/governance_timeline_projection.v1.json",
  "title": "governance_timeline_projection.v1",
  "type": "object",
  "required": ["schema_version", "events"],
  "properties": {
    "schema_version": { "const": "governance_timeline_projection.v1" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "timeline_event_type",
          "authority_ref",
          "authority_instance_ref",
          "authority_version",
          "timestamp",
          "severity",
          "summary",
          "continuity_impact",
          "caused_by_event_id"
        ],
        "properties": {
          "schema_version": { "const": "governance_timeline_event.v1" },
          "timeline_event_type": { "type": "string", "minLength": 1 },
          "authority_ref": { "type": "string", "minLength": 1 },
          "authority_instance_ref": { "type": "string", "minLength": 1 },
          "authority_version": { "type": "string", "minLength": 1 },
          "timestamp": { "type": ["string", "null"] },
          "severity": {
            "enum": [
              "info",
              "warning",
              "critical",
              "continuity_risk",
              "replay_risk",
              "authority_conflict"
            ]
          },
          "summary": { "type": "string", "minLength": 1 },
          "continuity_impact": { "type": "string", "minLength": 1 },
          "caused_by_event_id": { "type": ["string", "null"] },
          "event_id": { "type": "string" },
          "superseded_by": { "type": "string" },
          "activation_state": { "enum": ["activated", "deactivated"] },
          "drift_type": { "type": "string" },
          "drift": { "type": "object" },
          "diagnostic_rollup": { "type": "object" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
