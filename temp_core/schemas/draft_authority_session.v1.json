{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.waveframe.dev/draft_authority_session.v1.json",
  "title": "Draft Authority Session",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "created_at",
    "updated_at",
    "draft"
  ],
  "properties": {
    "schema_version": {
      "const": "draft_authority_session.v1"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "draft": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "protected_system",
        "governed_action",
        "contract_id",
        "contract_version",
        "governance_category",
        "approver_role",
        "approval_count",
        "escalation_threshold",
        "validity_days",
        "mutation_targets",
        "continuity_revalidation",
        "revocation_invalidates_resume"
      ],
      "properties": {
        "protected_system": {
          "type": ["string", "null"]
        },
        "governed_action": {
          "type": ["string", "null"]
        },
        "contract_id": {
          "type": ["string", "null"]
        },
        "contract_version": {
          "type": ["string", "null"]
        },
        "governance_category": {
          "type": ["string", "null"]
        },
        "approver_role": {
          "type": ["string", "null"]
        },
        "approval_count": {
          "type": ["string", "number", "null"]
        },
        "escalation_threshold": {
          "type": ["string", "number", "null"]
        },
        "validity_days": {
          "type": ["string", "number", "null"]
        },
        "mutation_targets": {
          "type": ["string", "array", "null"]
        },
        "continuity_revalidation": {
          "type": "boolean"
        },
        "revocation_invalidates_resume": {
          "type": "boolean"
        }
      }
    }
  }
}
