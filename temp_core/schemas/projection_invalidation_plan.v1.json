{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waveframe.ai/schemas/projection_invalidation_plan.v1.json",
  "title": "projection_invalidation_plan.v1",
  "type": "object",
  "required": [
    "schema_version",
    "change_type",
    "authority_ref",
    "invalidated_projections",
    "historically_persisted_artifacts",
    "recompute"
  ],
  "properties": {
    "schema_version": { "const": "projection_invalidation_plan.v1" },
    "change_type": { "type": "string", "minLength": 1 },
    "authority_ref": { "type": ["string", "null"] },
    "invalidated_projections": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "historically_persisted_artifacts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "recompute": { "type": "boolean" }
  },
  "additionalProperties": false
}
