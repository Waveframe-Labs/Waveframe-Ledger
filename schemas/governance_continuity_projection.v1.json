{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waveframe.ai/schemas/governance_continuity_projection.v1.json",
  "title": "governance_continuity_projection.v1",
  "type": "object",
  "required": ["schema_version", "authority_families"],
  "properties": {
    "schema_version": { "const": "governance_continuity_projection.v1" },
    "authority_families": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "authority_family",
          "continuity_posture",
          "active_authority",
          "superseded_authorities",
          "continuity_warnings",
          "replay_compatibility",
          "fragmentation",
          "replay_continuity_matrix",
          "continuity_observations"
        ],
        "properties": {
          "authority_family": { "type": "string", "minLength": 1 },
          "continuity_posture": {
            "enum": ["stable", "unstable", "fragmented", "ambiguous", "continuity_at_risk", "replay_degraded"]
          },
          "active_authority": { "type": ["string", "null"] },
          "superseded_authorities": { "type": "integer", "minimum": 0 },
          "continuity_warnings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "replay_compatibility": { "enum": ["complete", "degraded", "incomplete", "unknown"] },
          "fragmentation": {
            "type": "object",
            "required": ["fragmentation_detected", "fragmentation_type", "summary"],
            "properties": {
              "fragmentation_detected": { "type": "boolean" },
              "fragmentation_type": { "type": "string", "minLength": 1 },
              "summary": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "replay_continuity_matrix": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "authority_ref",
                "authority_version",
                "replay_compatible",
                "requires_revalidation",
                "continuity_preserved",
                "receipt_hash",
                "replay_readiness"
              ],
              "properties": {
                "authority_ref": { "type": "string", "minLength": 1 },
                "authority_version": { "type": "string", "minLength": 1 },
                "replay_compatible": { "type": "boolean" },
                "requires_revalidation": { "type": "boolean" },
                "continuity_preserved": { "type": "boolean" },
                "receipt_hash": { "type": ["string", "null"] },
                "replay_readiness": { "type": ["string", "null"] }
              },
              "additionalProperties": false
            }
          },
          "continuity_observations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "schema_version",
                "continuity_observation_type",
                "severity",
                "summary",
                "authority_ref"
              ],
              "properties": {
                "schema_version": { "const": "governance_continuity_observation.v1" },
                "continuity_observation_type": { "type": "string", "minLength": 1 },
                "severity": {
                  "enum": [
                    "info",
                    "warning",
                    "critical",
                    "continuity_risk",
                    "replay_risk",
                    "authority_conflict"
                  ]
                },
                "summary": { "type": "string", "minLength": 1 },
                "authority_ref": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
