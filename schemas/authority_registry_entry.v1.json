{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waveframe.ai/schemas/authority_registry_entry.v1.json",
  "title": "authority_registry_entry.v1",
  "type": "object",
  "required": [
    "schema_version",
    "authority_ref",
    "authority_version",
    "status",
    "protected_resource",
    "governed_action",
    "continuity_posture",
    "replay_readiness",
    "diagnostic_summary",
    "latest_bundle_hash",
    "latest_receipt_hash",
    "lifecycle_event_ids",
    "supersedes",
    "superseded_by",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "authority_registry_entry.v1" },
    "authority_ref": { "type": "string", "minLength": 1 },
    "authority_version": { "type": "string", "minLength": 1 },
    "status": {
      "enum": ["draft", "reviewed", "exported", "registered", "superseded", "revoked"]
    },
    "protected_resource": { "type": "string", "minLength": 1 },
    "governed_action": { "type": "string", "minLength": 1 },
    "continuity_posture": { "type": "string", "minLength": 1 },
    "replay_readiness": { "type": "string", "minLength": 1 },
    "diagnostic_summary": { "type": "object" },
    "latest_bundle_hash": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
    "latest_receipt_hash": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
    "lifecycle_event_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "supersedes": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
    "superseded_by": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
