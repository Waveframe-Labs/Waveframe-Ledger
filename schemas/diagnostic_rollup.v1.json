{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waveframe.ai/schemas/diagnostic_rollup.v1.json",
  "title": "diagnostic_rollup.v1",
  "type": "object",
  "required": [
    "schema_version",
    "authority_ref",
    "authority_version",
    "finding_count",
    "warning_count",
    "info_count",
    "domains",
    "highest_severity",
    "diagnostic_ids"
  ],
  "properties": {
    "schema_version": { "const": "diagnostic_rollup.v1" },
    "authority_ref": { "type": "string", "minLength": 1 },
    "authority_version": { "type": "string", "minLength": 1 },
    "finding_count": { "type": "integer", "minimum": 0 },
    "warning_count": { "type": "integer", "minimum": 0 },
    "info_count": { "type": "integer", "minimum": 0 },
    "domains": {
      "type": "array",
      "items": { "type": "string" }
    },
    "highest_severity": { "enum": ["none", "info", "warning", "error"] },
    "diagnostic_ids": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
