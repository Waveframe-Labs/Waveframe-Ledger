{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.waveframe.dev/publication_receipt.v1.json",
  "title": "Publication Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "publication_id",
    "authority_ref",
    "published_at",
    "published_by",
    "bundle_hash",
    "contract_hash",
    "manifest_hash",
    "semantic_artifact_hashes",
    "review_packet_hashes",
    "lineage_continuity",
    "compatibility_posture",
    "readiness_confirmations",
    "publication_notes",
    "semantic_compatibility_warnings",
    "immutable_inputs",
    "non_goals",
    "receipt_hash"
  ],
  "properties": {
    "schema_version": {
      "const": "publication_receipt.v1"
    },
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "publication_id": {
      "type": ["string", "null"]
    },
    "authority_ref": {
      "type": ["string", "null"]
    },
    "published_at": {
      "type": "string",
      "minLength": 1
    },
    "published_by": {
      "type": ["string", "null"]
    },
    "bundle_hash": {
      "type": "string",
      "minLength": 1
    },
    "contract_hash": {
      "type": ["string", "null"]
    },
    "manifest_hash": {
      "type": "string",
      "minLength": 1
    },
    "semantic_artifact_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "review_packet_hashes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lineage_continuity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_hash_present",
        "compilation_report_hash_present",
        "lineage_complete"
      ],
      "properties": {
        "source_hash_present": {
          "type": "boolean"
        },
        "compilation_report_hash_present": {
          "type": "boolean"
        },
        "lineage_complete": {
          "type": "boolean"
        }
      }
    },
    "compatibility_posture": {
      "type": "object",
      "additionalProperties": true,
      "required": ["compatible"]
    },
    "readiness_confirmations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantic_diagnostics_reviewed",
        "lineage_validated",
        "continuity_posture_reviewed",
        "replay_implications_reviewed",
        "lifecycle_implications_acknowledged"
      ],
      "properties": {
        "semantic_diagnostics_reviewed": {
          "type": "boolean"
        },
        "lineage_validated": {
          "type": "boolean"
        },
        "continuity_posture_reviewed": {
          "type": "boolean"
        },
        "replay_implications_reviewed": {
          "type": "boolean"
        },
        "lifecycle_implications_acknowledged": {
          "type": "boolean"
        }
      }
    },
    "publication_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["note_type", "text", "created_at"],
        "properties": {
          "note_type": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "created_at": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "semantic_compatibility_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "immutable_inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "receipt_hash": {
      "type": "string",
      "minLength": 1
    }
  }
}
