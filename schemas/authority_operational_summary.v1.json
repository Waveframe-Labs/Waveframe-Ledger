    "schema_version": { "const": "authority_operational_summary.v1" },
    "authority_ref": { "type": "string", "minLength": 1 },
    "authority_version": { "type": "string", "minLength": 1 },
    "protected_resource": { "type": ["string", "null"] },
    "governed_action": { "type": ["string", "null"] },
    "lifecycle": { "type": "object" },
    "drift_summary": { "type": "array" },
    "replay_readiness": { "type": "object" },
    "governance_meaning": {
      "type": "array",
