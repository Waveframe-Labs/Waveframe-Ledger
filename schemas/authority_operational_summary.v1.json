{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waveframe.ai/schemas/authority_operational_summary.v1.json",
  "title": "authority_operational_summary.v1",
  "type": "object",
  "required": [
    "schema_version",
    "authority_ref",
    "authority_version",
    "protected_resource",
    "governed_action",
    "lifecycle",
    "drift_summary",
    "replay_readiness",
    "governance_meaning",
    "relationship_graph"
  ],
