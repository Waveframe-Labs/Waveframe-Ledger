{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.waveframe.dev/execution_requirement_projection.v1.json",
  "title": "Execution Requirement Projection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "authority_ref",
    "compiled_contract_hash",
    "required_approvals",
    "independent_approval_required",
    "required_roles",
    "self_approval_prohibited",
    "attestation_required",
    "human_in_loop_required",
    "replay_evidence_required",
    "continuity_snapshot_required",
    "resume_validation_required",
    "delegation_expiry",
    "delegation_evidence_required",
    "temporal_validation_required",
    "capability_requirements",
    "runtime_enforced_by",
    "non_goals"
  ],
  "properties": {
    "schema_version": { "const": "execution_requirement_projection.v1" },
    "authority_ref": { "type": "string" },
    "compiled_contract_hash": { "type": ["string", "null"] },
    "required_approvals": { "type": "integer", "minimum": 0 },
    "independent_approval_required": { "type": "boolean" },
    "required_roles": { "type": "array", "items": { "type": "string" } },
    "self_approval_prohibited": { "type": "boolean" },
    "attestation_required": { "type": "boolean" },
    "human_in_loop_required": { "type": "boolean" },
    "replay_evidence_required": { "type": "boolean" },
    "continuity_snapshot_required": { "type": "boolean" },
    "resume_validation_required": { "type": "boolean" },
    "delegation_expiry": { "type": ["string", "null"] },
    "delegation_evidence_required": { "type": "boolean" },
    "temporal_validation_required": { "type": "boolean" },
    "capability_requirements": { "type": "array", "items": { "type": "object" } },
    "runtime_enforced_by": { "const": "Guard/Cloud" },
    "non_goals": { "type": "array", "items": { "type": "string" } }
  }
}
