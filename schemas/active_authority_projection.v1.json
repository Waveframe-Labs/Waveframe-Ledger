{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waveframe.ai/schemas/active_authority_projection.v1.json",
  "title": "active_authority_projection.v1",
  "type": "object",
  "required": ["schema_version", "active_authorities"],
  "properties": {
    "schema_version": { "const": "active_authority_projection.v1" },
    "active_authorities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "authority_family",
          "active_authority_ref",
          "active_authority_version",
          "status",
          "reason"
        ],
        "properties": {
          "authority_family": { "type": "string", "minLength": 1 },
          "active_authority_ref": { "type": ["string", "null"] },
          "active_authority_version": { "type": ["string", "null"] },
          "status": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
