{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waveframe.ai/schemas/governance_event.v1.json",
  "title": "governance_event.v1",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "timestamp",
    "authority_ref",
    "authority_version",
    "severity",
    "caused_by_event_id",
    "event_category",
    "immutability_posture"
  ],
  "properties": {
    "schema_version": { "const": "governance_event.v1" },
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "authority_ref": { "type": "string", "minLength": 1 },
    "authority_version": { "type": "string", "minLength": 1 },
    "severity": {
      "enum": [
        "info",
        "warning",
        "critical",
        "continuity_risk",
        "replay_risk",
        "authority_conflict"
      ]
    },
    "caused_by_event_id": { "type": ["string", "null"] },
    "event_category": {
      "enum": [
        "lifecycle",
        "continuity",
        "reconciliation",
        "projection",
        "replay",
        "lineage",
        "drift",
        "publication",
        "source"
      ]
    },
    "immutability_posture": { "const": "append_only" },
    "summary": { "type": "string" },
    "details": { "type": "object" }
  },
  "additionalProperties": false
}
