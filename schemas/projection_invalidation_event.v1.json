{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waveframe.ai/schemas/projection_invalidation_event.v1.json",
  "title": "projection_invalidation_event.v1",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "timestamp",
    "authority_ref",
    "authority_version",
    "severity",
    "caused_by_event_id",
    "event_category",
    "immutability_posture",
    "projection_name",
    "invalidated_by_event_id",
    "reason"
  ],
  "properties": {
    "schema_version": { "const": "projection_invalidation_event.v1" },
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": { "const": "projection_invalidated" },
    "timestamp": { "type": "string", "minLength": 1 },
    "authority_ref": { "type": "string", "minLength": 1 },
    "authority_version": { "type": "string", "minLength": 1 },
    "severity": {
      "enum": [
        "info",
        "warning",
        "critical",
        "continuity_risk",
        "replay_risk",
        "authority_conflict"
      ]
    },
    "caused_by_event_id": { "type": ["string", "null"] },
    "event_category": { "const": "projection" },
    "immutability_posture": { "const": "append_only" },
    "projection_name": { "type": "string", "minLength": 1 },
    "invalidated_by_event_id": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" }
  },
  "additionalProperties": false
}
