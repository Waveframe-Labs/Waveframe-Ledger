{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waveframe.ai/schemas/authority_lineage_projection.v1.json",
  "title": "authority_lineage_projection.v1",
  "type": "object",
  "required": [
    "schema_version",
    "authority_family",
    "nodes",
    "edges",
    "drift_indicators",
    "timeline"
  ],
  "properties": {
    "schema_version": { "const": "authority_lineage_projection.v1" },
    "authority_family": {
      "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "authority_ref",
          "authority_version",
          "status",
          "continuity_posture",
          "replay_readiness",
          "latest_receipt_hash",
          "supersedes",
          "superseded_by"
        ],
        "properties": {
          "authority_ref": { "type": "string", "minLength": 1 },
          "authority_version": { "type": "string", "minLength": 1 },
          "status": { "type": ["string", "null"] },
          "continuity_posture": { "type": ["string", "null"] },
          "replay_readiness": { "type": ["string", "null"] },
          "latest_receipt_hash": { "type": ["string", "null"] },
          "supersedes": { "type": ["string", "null"] },
          "superseded_by": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "relationship"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "relationship": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "drift_indicators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "authority_ref",
          "previous_authority_ref",
          "drift_type",
          "severity",
          "field",
          "from",
          "to"
        ],
        "properties": {
          "schema_version": { "const": "authority_drift_indicator.v1" },
          "authority_ref": { "type": "string", "minLength": 1 },
          "previous_authority_ref": { "type": "string", "minLength": 1 },
          "drift_type": { "type": "string", "minLength": 1 },
          "severity": {
            "enum": [
              "info",
              "warning",
              "critical",
              "continuity_risk",
              "replay_risk",
              "authority_conflict"
            ]
          },
          "field": { "type": "string", "minLength": 1 },
          "from": {},
          "to": {}
        },
        "additionalProperties": false
      }
    },
    "timeline": { "type": "array" }
  },
  "additionalProperties": false
}
